# AI-OJ v2 local/deploy environment template.
# Copy to .env for local Docker Compose runs. Real production values should be
# provided by CI/CD secrets or Docker secrets, not committed files.

COMPOSE_PROJECT_NAME=ai-oj-next

MYSQL_DATABASE=ai_oj_next
MYSQL_USER=aioj
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me

REDIS_PASSWORD=change-redis-me

RABBITMQ_DEFAULT_USER=aioj
RABBITMQ_DEFAULT_PASS=change-rabbit-me

NACOS_USERNAME=nacos
NACOS_PASSWORD=change-nacos-me
NACOS_ENABLED=true
NACOS_SERVER_ADDR=nacos:8848

SENTINEL_DASHBOARD=sentinel-dashboard:8858

JWT_ISSUER=ai-oj-next
JWT_HMAC_SECRET=replace-with-at-least-32-bytes-dev-secret
JWT_ACCESS_TTL=PT2H
JWT_REFRESH_TTL=P14D

AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.moonshot.cn/v1/chat/completions
AI_API_KEY=replace-in-secrets
AI_MODEL=moonshot-v1-32k

SANDBOX_ENDPOINT=http://sandbox:8090/execute
SANDBOX_TOKEN=replace-in-secrets

VITE_API_BASE_URL=http://localhost:8101

