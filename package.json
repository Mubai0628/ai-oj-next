{
  "name": "ai-oj-next",
  "private": true,
  "version": "0.1.0",
  "description": "AI-OJ v2 campus online judge platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @aioj/web-user && npm run build -w @aioj/web-admin",
    "build:user": "npm run build -w @aioj/web-user",
    "build:admin": "npm run build -w @aioj/web-admin",
    "dev:user": "npm run dev -w @aioj/web-user",
    "dev:admin": "npm run dev -w @aioj/web-admin",
    "typecheck": "npm run typecheck -w @aioj/web-user && npm run typecheck -w @aioj/web-admin"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "6.0.3",
    "typescript": "5.9.3",
    "vite": "8.0.13",
    "vue-tsc": "3.1.5"
  },
  "dependencies": {
    "@arco-design/web-vue": "2.58.0",
    "@vueuse/core": "14.1.0",
    "pinia": "3.0.4",
    "vue": "3.5.34",
    "vue-i18n": "11.4.4",
    "vue-router": "4.6.3"
  }
}
